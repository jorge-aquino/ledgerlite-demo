# Copy this file to .env and edit as needed.
# Never commit .env — it is in .gitignore.

POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=ledgerlite
POSTGRES_USER=ledger
POSTGRES_PASSWORD=ledgerpass

DATABASE_URL=postgres://ledger:ledgerpass@db:5432/ledgerlite?sslmode=disable

VAULT_ADDR=http://vault:8200
VAULT_TOKEN=root

APP_PORT=8080
